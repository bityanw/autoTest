# 服务配置
PORT=18681
NODE_ENV=development

# Windows Agent配置（已更新为实际地址）
WINDOWS_AGENT_URL=http://192.168.1.64:18082

# Maven私服配置
MAVEN_REPO_URL=http://nexus.company.com/repository/maven-releases/

# SVN配置
SVN_PROJECT_PATH=C:/svn/project

# Docker配置
DOCKER_NETWORK=autotest-network
APP_PORT=8888

# Playwright配置
PLAYWRIGHT_WORKSPACE=/opt/playwright-tests

# 报告配置
REPORT_OUTPUT_DIR=/opt/reports

# 邮件配置（可选）
EMAIL_ENABLED=false
EMAIL_HOST=smtp.company.com
EMAIL_PORT=587
EMAIL_FROM=test-platform@company.com
EMAIL_TO=team@company.com

# 日志配置
LOG_LEVEL=info
